<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="x_plotter">
  <xacro:arg name="demo_path" default="line_square_triangle"/>
  <xacro:arg name="enable_webots_trail" default="false"/>

  <xacro:property name="cfg" value="${xacro.load_yaml('$(find wall_climber)/config/x_plotter.yaml')}"/>
  <xacro:property name="board" value="${cfg['board']}"/>
  <xacro:property name="carriage" value="${cfg['carriage']}"/>
  <xacro:property name="pen" value="${cfg['pen']}"/>
  <xacro:property name="visuals" value="${cfg['visuals']}"/>

  <xacro:property name="w" value="${board['width']}"/>
  <xacro:property name="h" value="${board['height']}"/>
  <xacro:property name="rail_t" value="${visuals['rail_thickness']}"/>
  <xacro:property name="rail_d" value="${visuals['rail_depth']}"/>
  <xacro:property name="carriage_w" value="${carriage['width']}"/>
  <xacro:property name="carriage_h" value="${carriage['height']}"/>
  <xacro:property name="carriage_d" value="${carriage['depth']}"/>

  <material name="x_frame_dark">
    <color rgba="0.08 0.10 0.12 1.0"/>
  </material>
  <material name="x_rail_metal">
    <color rgba="0.55 0.59 0.64 1.0"/>
  </material>
  <material name="x_belt_black">
    <color rgba="0.01 0.01 0.012 1.0"/>
  </material>
  <material name="x_pulley_silver">
    <color rgba="0.76 0.78 0.82 1.0"/>
  </material>
  <material name="x_carriage_blue">
    <color rgba="0.05 0.35 0.72 1.0"/>
  </material>
  <material name="x_carriage_dark">
    <color rgba="0.08 0.11 0.14 1.0"/>
  </material>
  <material name="x_marker_body">
    <color rgba="0.98 0.98 0.95 1.0"/>
  </material>
  <material name="x_marker_tip">
    <color rgba="0.01 0.01 0.01 1.0"/>
  </material>

  <link name="base_link">
    <!-- Robot local frame: origin is board top-left, +X right, -Y down, -Z toward board. -->
    <visual>
      <origin xyz="${w / 2.0} 0 0" rpy="0 0 0"/>
      <geometry><box size="${w + rail_t * 2.0} ${rail_t} ${rail_d}"/></geometry>
      <material name="x_frame_dark"/>
    </visual>
    <visual>
      <origin xyz="${w / 2.0} ${-h} 0" rpy="0 0 0"/>
      <geometry><box size="${w + rail_t * 2.0} ${rail_t} ${rail_d}"/></geometry>
      <material name="x_frame_dark"/>
    </visual>
    <visual>
      <origin xyz="0 ${-h / 2.0} 0" rpy="0 0 0"/>
      <geometry><box size="${rail_t} ${h + rail_t * 2.0} ${rail_d}"/></geometry>
      <material name="x_frame_dark"/>
    </visual>
    <visual>
      <origin xyz="${w} ${-h / 2.0} 0" rpy="0 0 0"/>
      <geometry><box size="${rail_t} ${h + rail_t * 2.0} ${rail_d}"/></geometry>
      <material name="x_frame_dark"/>
    </visual>

    <visual>
      <origin xyz="${w / 2.0} ${-h * 0.18} 0.020" rpy="0 0 0"/>
      <geometry><box size="${w - 0.30} 0.018 0.018"/></geometry>
      <material name="x_rail_metal"/>
    </visual>
    <visual>
      <origin xyz="${w / 2.0} ${-h * 0.82} 0.020" rpy="0 0 0"/>
      <geometry><box size="${w - 0.30} 0.018 0.018"/></geometry>
      <material name="x_rail_metal"/>
    </visual>
    <visual>
      <origin xyz="${w * 0.18} ${-h / 2.0} 0.020" rpy="0 0 0"/>
      <geometry><box size="0.018 ${h - 0.30} 0.018"/></geometry>
      <material name="x_rail_metal"/>
    </visual>
    <visual>
      <origin xyz="${w * 0.82} ${-h / 2.0} 0.020" rpy="0 0 0"/>
      <geometry><box size="0.018 ${h - 0.30} 0.018"/></geometry>
      <material name="x_rail_metal"/>
    </visual>

    <!-- Visual crossed belts. They are intentionally visual-only for this foundation. -->
    <visual>
      <origin xyz="${w / 2.0} ${-h / 2.0} 0.038" rpy="0 0 ${-visuals['belt_angle_rad']}"/>
      <geometry><box size="${visuals['belt_diagonal_length']} ${visuals['belt_width']} ${visuals['belt_depth']}"/></geometry>
      <material name="x_belt_black"/>
    </visual>
    <visual>
      <origin xyz="${w / 2.0} ${-h / 2.0} 0.050" rpy="0 0 ${visuals['belt_angle_rad']}"/>
      <geometry><box size="${visuals['belt_diagonal_length']} ${visuals['belt_width']} ${visuals['belt_depth']}"/></geometry>
      <material name="x_belt_black"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.060" rpy="0 0 0"/>
      <geometry><cylinder radius="${visuals['pulley_radius']}" length="0.030"/></geometry>
      <material name="x_pulley_silver"/>
    </visual>
    <visual>
      <origin xyz="${w} 0 0.060" rpy="0 0 0"/>
      <geometry><cylinder radius="${visuals['pulley_radius']}" length="0.030"/></geometry>
      <material name="x_pulley_silver"/>
    </visual>
    <visual>
      <origin xyz="0 ${-h} 0.060" rpy="0 0 0"/>
      <geometry><cylinder radius="${visuals['pulley_radius']}" length="0.030"/></geometry>
      <material name="x_pulley_silver"/>
    </visual>
    <visual>
      <origin xyz="${w} ${-h} 0.060" rpy="0 0 0"/>
      <geometry><cylinder radius="${visuals['pulley_radius']}" length="0.030"/></geometry>
      <material name="x_pulley_silver"/>
    </visual>

    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <joint name="x_carriage_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="x_carriage_stage"/>
    <origin xyz="0 0 0.080" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="${board['width']}" effort="120" velocity="${carriage['speed']}"/>
    <dynamics damping="1.0" friction="0.0"/>
  </joint>

  <link name="x_carriage_stage">
    <visual>
      <origin xyz="0 ${-h / 2.0} 0" rpy="0 0 0"/>
      <geometry><box size="0.030 ${h - 0.25} 0.024"/></geometry>
      <material name="x_rail_metal"/>
    </visual>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="y_carriage_joint" type="prismatic">
    <parent link="x_carriage_stage"/>
    <child link="x_plotter_carriage"/>
    <origin xyz="0 0 0.035" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="${board['height']}" effort="120" velocity="${carriage['speed']}"/>
    <dynamics damping="1.0" friction="0.0"/>
  </joint>

  <link name="x_plotter_carriage">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${carriage_w} ${carriage_h} ${carriage_d}"/></geometry>
      <material name="x_carriage_blue"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <geometry><box size="${carriage_w * 0.72} ${carriage_h * 0.55} 0.018"/></geometry>
      <material name="x_carriage_dark"/>
    </visual>
    <visual>
      <origin xyz="${-carriage_w * 0.52} 0 0.010" rpy="0 0 0"/>
      <geometry><box size="0.075 0.040 0.030"/></geometry>
      <material name="x_belt_black"/>
    </visual>
    <visual>
      <origin xyz="${carriage_w * 0.52} 0 0.010" rpy="0 0 0"/>
      <geometry><box size="0.075 0.040 0.030"/></geometry>
      <material name="x_belt_black"/>
    </visual>
    <inertial>
      <mass value="${carriage['mass']}"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
  </link>

  <joint name="pen_slide_joint" type="prismatic">
    <parent link="x_plotter_carriage"/>
    <child link="x_plotter_pen_stage"/>
    <origin xyz="0 0 ${-carriage_d / 2.0}" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="${pen['up_position']}" upper="${pen['down_position']}" effort="35" velocity="${pen['slide_velocity']}"/>
    <dynamics damping="0.2" friction="0.0"/>
  </joint>

  <link name="x_plotter_pen_stage">
    <visual>
      <origin xyz="0 0 ${-pen['length'] / 2.0}" rpy="0 0 0"/>
      <geometry><cylinder radius="${pen['radius']}" length="${pen['length']}"/></geometry>
      <material name="x_marker_body"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${-pen['length'] - 0.010}" rpy="0 0 0"/>
      <geometry><cylinder radius="${pen['radius'] * 0.62}" length="0.020"/></geometry>
      <material name="x_marker_tip"/>
    </visual>
    <inertial>
      <mass value="0.06"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <webots>
    <controller type="extern"/>
    <plugin type="wall_climber.x_plotter.x_plotter_robot_plugin.XPlotterRobotPlugin">
      <board_width>${board['width']}</board_width>
      <board_height>${board['height']}</board_height>
      <board_center_x>${board['center_x']}</board_center_x>
      <board_center_z>${board['center_z']}</board_center_z>
      <board_surface_y>${board['surface_y']}</board_surface_y>
      <board_origin>${board['origin']}</board_origin>
      <board_x_direction>${board['x_direction']}</board_x_direction>
      <board_y_direction>${board['y_direction']}</board_y_direction>
      <carriage_plane_y>${carriage['plane_y']}</carriage_plane_y>
      <margin_left>${board['margin_left']}</margin_left>
      <margin_right>${board['margin_right']}</margin_right>
      <margin_top>${board['margin_top']}</margin_top>
      <margin_bottom>${board['margin_bottom']}</margin_bottom>
      <initial_x>${carriage['initial_x']}</initial_x>
      <initial_y>${carriage['initial_y']}</initial_y>
      <carriage_speed>${carriage['speed']}</carriage_speed>
      <x_joint_name>x_carriage_joint</x_joint_name>
      <y_joint_name>y_carriage_joint</y_joint_name>
      <pen_joint_name>pen_slide_joint</pen_joint_name>
      <optional_belt_devices>x_plotter_belt_endpoint_a,x_plotter_belt_endpoint_b</optional_belt_devices>
      <pen_slide_velocity>${pen['slide_velocity']}</pen_slide_velocity>
      <pen_up_position>${pen['up_position']}</pen_up_position>
      <pen_down_position>${pen['down_position']}</pen_down_position>
      <enable_webots_trail>$(arg enable_webots_trail)</enable_webots_trail>
      <trail_half_width>${visuals['trail_half_width']}</trail_half_width>
      <trail_min_spacing>${visuals['trail_min_spacing']}</trail_min_spacing>
      <trail_max>${visuals['trail_max']}</trail_max>
      <demo_path>$(arg demo_path)</demo_path>
    </plugin>
  </webots>
</robot>
