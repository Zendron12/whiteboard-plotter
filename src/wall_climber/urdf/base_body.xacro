<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="base_body" params="">
        <xacro:property name="robot_cfg" value="${xacro.load_yaml('$(find wall_climber)/config/cable_robot.yaml')}"/>
        <xacro:property name="carriage_cfg" value="${robot_cfg['carriage']}"/>
        <xacro:property name="attach_left_local_y" value="${-carriage_cfg['attachment_left_y']}"/>
        <xacro:property name="attach_right_local_y" value="${-carriage_cfg['attachment_right_y']}"/>
        <xacro:property name="mount_tip_z" value="${-(carriage_cfg['depth'] / 2.0) + 0.002}"/>
        <xacro:property name="mount_sphere_radius" value="0.0050"/>
        <xacro:property name="mount_sphere_highlight_radius" value="${mount_sphere_radius * 0.70}"/>
        <xacro:property name="mount_stem_radius" value="0.0032"/>
        <xacro:property name="mount_stem_length" value="0.006"/>
        <xacro:property name="top_strip_width" value="${carriage_cfg['width'] - 0.050}"/>
        <xacro:property name="top_strip_height" value="${carriage_cfg['height'] * 0.22}"/>
        <xacro:property name="service_panel_width" value="${carriage_cfg['width'] * 0.18}"/>
        <xacro:property name="service_panel_height" value="${carriage_cfg['height'] * 0.72}"/>
        <xacro:property name="service_panel_x" value="${(carriage_cfg['width'] * 0.5) - (service_panel_width * 0.5) - 0.016}"/>
        <xacro:property name="service_panel_y" value="${-(carriage_cfg['height'] * 0.13)}"/>

        <link name="base_link">
            <visual>
                <geometry><box size="0.001 0.001 0.001"/></geometry>
            </visual>
            <inertial>
                <mass value="0.01"/>
                <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
            </inertial>
        </link>

        <joint name="chassis_joint" type="fixed">
            <parent link="base_link"/>
            <child link="chassis"/>
            <origin xyz="0 0 ${carriage_cfg['root_to_chassis_z']}" rpy="0 0 0"/>
        </joint>

        <link name="chassis">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="${carriage_cfg['width']} ${carriage_cfg['height']} ${carriage_cfg['depth']}"/>
                </geometry>
                <material name="robot_orange_mat">
                    <color rgba="1.0 0.35 0.05 1.0"/>
                </material>
            </visual>
            <visual>
                <origin xyz="-0.010 ${carriage_cfg['height'] * 0.27} ${carriage_cfg['depth'] * 0.05}" rpy="0 0 0"/>
                <geometry>
                    <box size="${top_strip_width} ${top_strip_height} ${carriage_cfg['depth'] * 0.32}"/>
                </geometry>
                <material name="robot_dark_top_trim">
                    <color rgba="0.15 0.18 0.22 1.0"/>
                </material>
            </visual>
            <visual>
                <origin xyz="${service_panel_x} ${service_panel_y} ${carriage_cfg['depth'] * 0.08}" rpy="0 0 0"/>
                <geometry>
                    <box size="${service_panel_width} ${service_panel_height} ${carriage_cfg['depth'] * 0.28}"/>
                </geometry>
                <material name="robot_service_panel_mat">
                    <color rgba="0.22 0.25 0.30 1.0"/>
                </material>
            </visual>
            <visual>
                <origin xyz="${service_panel_x} ${service_panel_y} ${carriage_cfg['depth'] * 0.20}" rpy="0 0 0"/>
                <geometry>
                    <box size="${service_panel_width * 0.72} ${service_panel_height * 0.52} ${carriage_cfg['depth'] * 0.08}"/>
                </geometry>
                <material name="robot_service_panel_highlight_mat">
                    <color rgba="0.40 0.45 0.52 1.0"/>
                </material>
            </visual>

            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="${carriage_cfg['width']} ${carriage_cfg['height']} ${carriage_cfg['depth']}"/>
                </geometry>
            </collision>

            <inertial>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <mass value="${carriage_cfg['mass']}"/>
                <inertia ixx="0.006" ixy="0.0" ixz="0.0" iyy="0.006" iyz="0.0" izz="0.006"/>
            </inertial>
        </link>

        <joint name="left_cable_mount_joint" type="fixed">
            <parent link="chassis"/>
            <child link="left_cable_mount"/>
            <origin xyz="${carriage_cfg['attachment_left_x']} ${attach_left_local_y} ${mount_tip_z}" rpy="0 0 0"/>
        </joint>

        <link name="left_cable_mount">
            <visual>
                <geometry><sphere radius="${mount_sphere_radius}"/></geometry>
                <material name="cable_mount_ball_mat">
                    <color rgba="0.86 0.10 0.10 1.0"/>
                </material>
            </visual>
            <visual>
                <origin xyz="0 0 0.0007" rpy="0 0 0"/>
                <geometry><sphere radius="${mount_sphere_highlight_radius}"/></geometry>
                <material name="cable_mount_ball_highlight_mat">
                    <color rgba="1.0 0.34 0.30 1.0"/>
                </material>
            </visual>
            <visual>
                <origin xyz="0 0 ${mount_stem_length / 2.0}" rpy="0 0 0"/>
                <geometry><cylinder radius="${mount_stem_radius}" length="${mount_stem_length}"/></geometry>
                <material name="robot_dark_grey_mat">
                    <color rgba="0.20 0.22 0.26 1.0"/>
                </material>
            </visual>
            <collision>
                <geometry><sphere radius="${mount_sphere_radius}"/></geometry>
            </collision>
            <collision>
                <origin xyz="0 0 ${mount_stem_length / 2.0}" rpy="0 0 0"/>
                <geometry><cylinder radius="${mount_stem_radius}" length="${mount_stem_length}"/></geometry>
            </collision>
            <inertial>
                <mass value="0.015"/>
                <inertia ixx="1.4e-5" ixy="0.0" ixz="0.0" iyy="1.4e-5" iyz="0.0" izz="1.4e-5"/>
            </inertial>
        </link>

        <joint name="right_cable_mount_joint" type="fixed">
            <parent link="chassis"/>
            <child link="right_cable_mount"/>
            <origin xyz="${carriage_cfg['attachment_right_x']} ${attach_right_local_y} ${mount_tip_z}" rpy="0 0 0"/>
        </joint>

        <link name="right_cable_mount">
            <visual>
                <geometry><sphere radius="${mount_sphere_radius}"/></geometry>
                <material name="cable_mount_ball_mat">
                    <color rgba="0.86 0.10 0.10 1.0"/>
                </material>
            </visual>
            <visual>
                <origin xyz="0 0 0.0007" rpy="0 0 0"/>
                <geometry><sphere radius="${mount_sphere_highlight_radius}"/></geometry>
                <material name="cable_mount_ball_highlight_mat">
                    <color rgba="1.0 0.34 0.30 1.0"/>
                </material>
            </visual>
            <visual>
                <origin xyz="0 0 ${mount_stem_length / 2.0}" rpy="0 0 0"/>
                <geometry><cylinder radius="${mount_stem_radius}" length="${mount_stem_length}"/></geometry>
                <material name="robot_dark_grey_mat">
                    <color rgba="0.20 0.22 0.26 1.0"/>
                </material>
            </visual>
            <collision>
                <geometry><sphere radius="${mount_sphere_radius}"/></geometry>
            </collision>
            <collision>
                <origin xyz="0 0 ${mount_stem_length / 2.0}" rpy="0 0 0"/>
                <geometry><cylinder radius="${mount_stem_radius}" length="${mount_stem_length}"/></geometry>
            </collision>
            <inertial>
                <mass value="0.015"/>
                <inertia ixx="1.4e-5" ixy="0.0" ixz="0.0" iyy="1.4e-5" iyz="0.0" izz="1.4e-5"/>
            </inertial>
        </link>
    </xacro:macro>
</robot>
