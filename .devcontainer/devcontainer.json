{
  "name": "Artie ROS 2 Workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "hisham",
  "runArgs": [
    "--net=host",
    "--env=DISPLAY=${env:DISPLAY}",
    "--env=WAYLAND_DISPLAY=${env:WAYLAND_DISPLAY}",
    "--env=XDG_RUNTIME_DIR=${env:XDG_RUNTIME_DIR}",
    "--env=QT_QPA_PLATFORM=xcb",
    "--volume=/tmp/.X11-unix:/tmp/.X11-unix:rw",
    "--gpus=all",
    "--env=NVIDIA_DRIVER_CAPABILITIES=all"
  ],
  "forwardPorts": [8080, 9090],
  "portsAttributes": {
    "8080": {
      "label": "Wall Climber Web UI",
      "onAutoForward": "openBrowser"
    },
    "9090": {
      "label": "ROSBridge WebSocket",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-python.python",
        "ms-iot.vscode-ros"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y python3-colcon-common-extensions ros-humble-xacro ros-humble-webots-ros2 ros-humble-rosbridge-suite libxcb-cursor0 python3-pip && pip3 install fastapi uvicorn python-multipart"
}
